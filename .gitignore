# Git Ignore rules for Fahem project

# Ignore local temporary/sensitive files
ignore/
.ignore/

# Ignore Python compilation cache
__pycache__/
*.pyc

# Ignore node modules and build outputs
node_modules/
dist/
.next/
out/
build/

# Ignore local environment files that contain secrets
.env
.env.local
.env.development.local
.env.test.local
.env.production.local

# OS files
.DS_Store
Thumbs.db

# Executables and large binaries
agy.exe
agy.exe*
*.exe
*.old

# Debug logs
*.log
firebase-debug.log
build_log*.txt

# Ignore all temporary folders and subfolders recursively (e.g., temp/ and temp/bible_progress/)
temp/
**/temp/
temp_test_book_1.pdf

# Ignore scratchpad / experimental scripts
scratches/
scratch/
**/scratch/

# Ignore user screenshots and logos
screenshots/
logos/

# Ignore local launcher scripts
Launch Agents.bat
launch_agents.ps1

# Ignore test and scratch scripts in agents folder (not used in production)
agents/test_*.py
