rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    
    // User Uploads: Allow public reading and writes under user_uploads
    match /user_uploads/{userId}/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Admin Ingested/Uploaded books and curricula
    match /admin_uploads/{adminId}/{allPaths=**} {
      allow read, write: if true;
    }
    
    // Ministry of Education Egypt Library
    match /ellibrary_moe_gov_eg/{allPaths=**} {
      allow read, write: if true;
    }

    // Capture folders with spaces dynamically without syntax errors
    match /{folderName}/{allPaths=**} {
      allow read, write: if folderName == "MOE Library" || folderName == "Profile Pictures" || folderName == "profile_pictures";
    }

    // Generic fallback for any other files
    match /{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
