        {
          "id": "p39-b9",
          "parent": "",
          "type": "example",
          "label": "TRY IT",
          "title": "Exploring the shell",
          "dir": "ltr"
        },
        {
          "id": "p39-b10",
          "parent": "p39-b9",
          "type": "paragraph",
          "text": "Running code interactively is a great way to learn how Python works. Open a Python shell on your computer, or use the one at python.org/shell (https://openstax.org/r/100pythonshell). Then enter any Python code, one line at a time, to see the result. Here are a few expressions to try:",
          "dir": "ltr"
        },
        {
          "id": "p39-b11",
          "parent": "p39-b9",
          "type": "list",
          "ordered": false,
          "items": [
            "x = 5",
            "3*x - 5",
            "3 * (x-5)",
            "x",
            "type(1)",
            "type('1')",
            "str(1)",
            "int('1')",
            "abs(-5)"
          ],
          "dir": "ltr"
        }
      ],
