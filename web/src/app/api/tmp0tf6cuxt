        {
          "id": "p10-b7",
          "parent": "p10-b4",
          "type": "code",
          "text": "song = input()\nprint(\"Cool! I like\", song, \"too.\")\nprint(\"What is your favorite song?\") song = input() print(\"Cool! I like\", song, \"too.\")",
          "lang": "python",
          "dir": "ltr"
        },
        {
          "id": "p10-b8",
          "parent": "p10-b4",
          "type": "list",
          "ordered": false,
          "items": [
            "The modified program reads two lines of input: name and song. Add your favorite song to the Input box below your name, and run the program again."
          ],
          "dir": "ltr"
        },
        {
          "id": "p10-b9",
          "parent": "p10-b4",
