          "parent": "p8-c1",
          "type": "paragraph",
          "text": "Online music streaming; ch 1, video 1 (https://www.openstax.org/r/music-streaming)",
          "dir": "ltr"
        },
        {
          "id": "p8-c2",
          "parent": "",
          "type": "callout",
          "label": "CONCEPTS IN PRACTICE",
          "title": "Computers and programs",
          "dir": "ltr"
        },
        {
          "id": "p8-q1",
          "parent": "p8-c2",
          "type": "question",
          "prompt": "1. How many types of programs were described in the animation?",
